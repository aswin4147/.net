@model IEnumerable<BusinessLogic.Models.RestaurantOrder>
@{
    ViewData["Title"] = "Kitchen Screen";
}

<div class="container mt-4">
    <h2>🍳 Kitchen Display</h2>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>Ticket #</th>
                <th>Table</th>
                <th>Server</th>
                <th>Items (Qty x Name)</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.Id</td>
                        <td class="fw-bold">@order.TableNumber</td>
                        <td>@order.ServerName</td>
                        <td>
                            <ul class="list-unstyled mb-0">
                                @foreach (var item in order.OrderItems)
                                {
                                    <li><span class="badge bg-primary fs-6 mb-1">@item.Quantity x @item.FoodItem</span></li>
                                }
                            </ul>
                        </td>
                        <td class="text-danger fw-bold">@order.Status</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center">No active orders!</td></tr>
            }
        </tbody>
    </table>
</div>