@model BusinessLogic.Models.RestaurantOrder
@{
    ViewData["Title"] = "Take Order";
}

<div class="container mt-4">
    <div class="card border-primary shadow">
        <div class="card-header bg-primary text-white"><h4>📋 New Table Order</h4></div>
        <div class="card-body">
            <form asp-action="TakeOrder" method="post">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="TableNumber" class="fw-bold">Table Number</label>
                        <input asp-for="TableNumber" type="number" min="1" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ServerName" class="fw-bold">Server Name</label>
                        <input asp-for="ServerName" class="form-control" required />
                    </div>
                </div>

                <hr />
                <h5>Order Items</h5>

                <div id="items-container">
                    <div class="row mb-2 item-row">
                        <div class="col-md-8">
                            <select name="OrderItems[0].FoodItem" class="form-select" required>
                                <option value="">-- Select --</option>
                                <option value="Cheeseburger">Cheeseburger</option>
                                <option value="Pepperoni Pizza">Pepperoni Pizza</option>
                                <option value="Caesar Salad">Caesar Salad</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <input name="OrderItems[0].Quantity" type="number" min="1" value="1" class="form-control" required />
                        </div>
                    </div>
                </div>

                <button type="button" class="btn btn-outline-primary mb-4" onclick="addItemRow()">+ Add Another Item</button>
                <button type="submit" class="btn btn-success w-100 fs-5">🔥 Send to Kitchen</button>
            </form>
        </div>
    </div>
</div>

<script>
    let itemIndex = 1;
    function addItemRow() {
        const container = document.getElementById('items-container');
        const newRow = `
            <div class="row mb-2 item-row">
                <div class="col-md-8">
                    <select name="OrderItems[${itemIndex}].FoodItem" class="form-select" required>
                        <option value="">-- Select --</option>
                        <option value="Cheeseburger">Cheeseburger</option>
                        <option value="Pepperoni Pizza">Pepperoni Pizza</option>
                        <option value="Caesar Salad">Caesar Salad</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input name="OrderItems[${itemIndex}].Quantity" type="number" min="1" value="1" class="form-control" required />
                </div>
            </div>`;
        container.insertAdjacentHTML('beforeend', newRow);
        itemIndex++;
    }
</script>