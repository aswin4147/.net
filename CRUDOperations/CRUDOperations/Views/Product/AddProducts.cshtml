<!-- Make sure to change 'YourNamespace' to your actual project's namespace! -->
@model BusinessLogic.Models.ProductData

@{
    ViewData["Title"] = "Add New Product";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-success">

                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Add New Product</h4>
                </div>

                <div class="card-body">

                    <!-- asp-action tells the form to POST to the AddProduct method in your controller -->
                    <form asp-action="AddProducts" method="post">

                        <!-- Product Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label text-muted fw-bold">Product Name</label>
                            <input asp-for="Name" class="form-control" placeholder="Enter product name" required />
                        </div>

                        <!-- Price -->
                        <div class="mb-3">
                            <label asp-for="Price" class="form-label text-muted fw-bold">Price ($)</label>
                            <!-- type="number" with step="0.01" ensures the browser allows decimal values -->
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" required />
                        </div>

                        <!-- Stock Quantity -->
                        <div class="mb-4">
                            <label asp-for="Stock" class="form-label text-muted fw-bold">Stock Quantity</label>
                            <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" required />
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Save Product</button>
                            <a href="/Product/Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>