<!-- Make sure to change 'YourNamespace' to your actual project's namespace! -->
@model BusinessLogic.Models.MovieDetails

@{
    ViewData["Title"] = "Add New Movie";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-primary">

                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">🎬 Add New Movie</h4>
                </div>

                <div class="card-body">

                    <!-- asp-action tells the form to POST to the AddMovie method in your controller -->
                    <form asp-action="AddMovie" method="post">

                        <!-- Movie Title -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label text-muted fw-bold">Movie Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g., Inception" required />
                        </div>

                        <!-- Director -->
                        <div class="mb-3">
                            <label asp-for="Director" class="form-label text-muted fw-bold">Director</label>
                            <input asp-for="Director" class="form-control" placeholder="e.g., Christopher Nolan" required />
                        </div>

                        <!-- Price / Rental Cost -->
                        <div class="mb-4">
                            <label asp-for="Price" class="form-label text-muted fw-bold">Price ($)</label>
                            <!-- type="number" with step="0.01" ensures the browser allows decimal values like 19.99 -->
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" required />
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Save Movie</button>
                            <!-- Update the href to point to wherever your Movie list is located -->
                            <a asp-action="ViewMovies" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>