<!-- Make sure to change 'YourNamespace' to your actual project's namespace! -->
@model BusinessLogic.Models.BookData

@{
    ViewData["Title"] = "Add New Book";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-success">

                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">📚 Add New Book</h4>
                </div>

                <div class="card-body">

                    <form asp-action="AddBook" method="post">

                        <!-- Book Title -->
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label text-muted fw-bold">Book Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g., The Hobbit" required />
                        </div>

                        <!-- Author -->
                        <div class="mb-3">
                            <label asp-for="Author" class="form-label text-muted fw-bold">Author</label>
                            <input asp-for="Author" class="form-control" placeholder="e.g., J.R.R. Tolkien" required />
                        </div>

                        <!-- Price -->
                        <div class="mb-4">
                            <label asp-for="Price" class="form-label text-muted fw-bold">Price ($)</label>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" required />
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Save Book</button>
                            <a href="#" class="btn btn-outline-secondary">Cancel</a>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>