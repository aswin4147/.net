<!-- Make sure to change 'YourNamespace' to your actual project's namespace! -->
@model IEnumerable<BusinessLogic.Models.BookData>

@{
    Layout = "_TestLayout";
    ViewData["Title"] = "Book Library";
}

<div class="container mt-5">

    <!-- Header area with Title and Add Button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📚 Book Library</h2>
        <a asp-action="AddBook" class="btn btn-success">+ Add New Book</a>
        <form asp-controller="Book" asp-action="Logout" method="post" class="d-inline">
            <button type="submit" class="btn btn-link nav-link text-dark">Logout</button>
        </form>
    </div>

    <!-- The Data Table -->
    <div class="card shadow-sm border-success">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-success">
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Price</th>
                        <th>Status</th>
                        @* <th class="text-end">Actions</th> *@
                    </tr>
                </thead>
                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        @foreach (var book in Model)
                        {
                            <partial name="_ViewBookPartial" model="book"></partial>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted fs-5">
                                No books found in the library. Click "Add New Book" to get started!
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>
    </div>
</div>