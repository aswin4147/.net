@model BusinessLogic.Models.BookLogin

@{
    ViewData["Title"] = "Log In";
}

<div class="row mt-5">
    <div class="col-md-4 offset-md-4">
        <h2 class="text-center">Welcome Back</h2>
        <hr />

        <form asp-action="Login" method="post">
            <!-- Shows any overall login errors, like "Invalid email or password" -->
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Email Input -->
            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Password Input -->
            <div class="form-group mb-4">
                <label asp-for="Password" class="control-label">Password</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- Submit Button -->
            <div class="form-group mb-3">
                <button type="submit" class="btn btn-success w-100">Log In</button>
            </div>

            <div class="text-center">
                <p>Don't have an account? <a href="/Account/Register">Register here</a></p>
            </div>
        </form>
    </div>
</div>

<!-- Enable Client-Side Validation -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}