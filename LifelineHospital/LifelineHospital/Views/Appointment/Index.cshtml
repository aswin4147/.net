@model IEnumerable<BusinessLogic.Models.Appointment>
@{
    ViewData["Title"] = "Appointments List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Appointments List</h2>
    <a asp-action="Create" class="btn btn-primary">Schedule New Appointment</a>
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Appointment ID</th>
            <th>Patient ID</th>
            <th>Patient Name</th>
            <th>Date & Time</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.AppointmentId</td>
                    <td>@item.PatientId</td>
                    <td>@(item.Patient != null ? item.Patient.PatientName : "Unknown")</td>
                    <td>@item.AppointmentDate.ToString("f")</td>
                    <td>
                        <a asp-controller="Patient" asp-action="Details" asp-route-id="@item.PatientId" class="btn btn-info btn-sm">View Patient Details</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <!-- Updated colspan to 5 to account for the new Actions column -->
                <td colspan="5" class="text-center">No appointments scheduled.</td>
            </tr>
        }
    </tbody>
</table>