@model LifelineHospital.Models.Appointment
@{
    ViewData["Title"] = "Schedule Appointment";
}

<h2>Schedule Appointment</h2>
<hr />

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div class="form-group mb-3">
                <label asp-for="PatientId" class="form-label">Patient ID</label>
                <input asp-for="PatientId" type="number" class="form-control" placeholder="Enter Patient ID" />
                <span asp-validation-for="PatientId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AppointmentDate" class="form-label">Appointment Date & Time</label>
                <input asp-for="AppointmentDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="AppointmentDate" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Schedule</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}